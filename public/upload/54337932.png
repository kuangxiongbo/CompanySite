<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>404 - 页面未找到</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            background: #fff;
            font-family: sans-serif;
        }

        .error-code {
            font-size: 8vw;
            font-weight: 700;
            color: #333;
            margin-bottom: 1vw;
        }

        .error-text {
            font-size: 2vw;
            color: #666;
            text-align: center;
            padding: 0 20px;
        }
    </style>
</head>
<body>
    <div class="error-code">404</div>
</body>
</html>
