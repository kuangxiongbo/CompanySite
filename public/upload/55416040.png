<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>404</title>
    <style>
        body { margin: 0; height: 100vh; display: flex; flex-direction: column; align-items: center; justify-content: center; background: #f5f5f5; font-family: sans-serif; }
        h1 { font-size: 6rem; margin: 0; color: #666; }
        p { font-size: 1rem; color: #888; margin: 1rem 0 2rem; }
        a { padding: 8px 16px; background: #2196f3; color: white; text-decoration: none; border-radius: 4px; }
    </style>
</head>
<body>
    <h1>404</h1>
    <p>页面不存在</p>
    <a href="/">返回首页</a>
</body>
</html>